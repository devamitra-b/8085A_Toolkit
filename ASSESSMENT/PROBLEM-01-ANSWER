MVI A, 0AH      ; Load 10 into accumulator
STA 2000H       ; Store in memory location of 'a'
MVI A, 14H      ; Load 20 into accumulator
STA 2001H       ; Store in memory location of 'b'
LDA 2000H       ; Load 'a' into accumulator
MOV B, A        ; Move 'a' to register B
LDA 2001H       ; Load 'b' into accumulator
ADD B           ; A = A + B (b + a)
STA 2002H       ; Store result in 'c'
HLT             ; Stop program
